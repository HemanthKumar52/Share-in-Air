# ─────────────────────────────────────────────────────────────────────────────
#  Share in Air — environment
# ─────────────────────────────────────────────────────────────────────────────
#
#  Realtime SIGNALING runs over Supabase Realtime (open source, free tier, and
#  fully self-hostable). The WebSocket connection goes browser -> Supabase, so it
#  works perfectly on Vercel (which can't host a long-lived WS server itself).
#
#  >>> Without these set, the app still runs in LOCAL DEMO mode: it falls back to
#      a BroadcastChannel transport that connects multiple tabs on the SAME
#      machine. Set these two vars to enable real cross-device, same-WiFi sharing.
#
#  Get them in 60 seconds:
#    1. Create a free project at https://supabase.com/dashboard (or self-host).
#    2. Project Settings -> API -> copy the "Project URL" and the "anon public" key.
#    3. Paste below (and add the same two vars in Vercel -> Project -> Settings ->
#       Environment Variables).
#
#  Only the anon key is used, only for ephemeral Realtime channels. No database
#  tables, no rows, no auth, no media ever touch Supabase — screens and files
#  flow strictly peer-to-peer over WebRTC.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: a comma-separated list of extra ICE servers (STUN/TURN) as JSON.
# Same-WiFi peers connect directly via host candidates and rarely need these.
# For sharing across different networks you may add an open-source TURN relay
# (e.g. self-hosted coturn). Leave blank to use the bundled public STUN servers.
# Example: [{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]
NEXT_PUBLIC_ICE_SERVERS=
